{
  "name": "tricore-events",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "atlas:dev-ip": "node scripts/ensure-atlas-dev-access.mjs --wait",
    "dev": "npm run atlas:dev-ip && concurrently \"npm run dev --workspace server\" \"node scripts/wait-for-port.mjs 127.0.0.1 5000 30000 && npm run dev --workspace client\"",
    "server": "npm run dev --workspace server",
    "client": "npm run dev --workspace client",
    "build": "npm run build --workspace client",
    "build:client": "npm run build --workspace client",
    "start": "npm run start:server",
    "start:server": "npm run start --workspace server",
    "validate:workflow": "node server/scripts/run-validation-suite.js",
    "deploy": "npm run build:client && npm run start:server",
    "lint": "npm run lint --workspace client"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "claude-ai": "^1.2.3"
  }
}
